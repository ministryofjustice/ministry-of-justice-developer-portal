{
  "ignorePaths": [
    "dist/",
    "out/",
    "content/docs/**",
    "**/node_modules/**",
    "**/*.drawio",
    "**/*.svg",
    "**/package*.json",
    "**/*.xml",
    "**/*.tsbuildinfo",
    "3e9410cef31dd9cec64ad567efc959afd88a591c/**" // SLSA action checkout (see .gitignore)
  ],
  "language": "en",
  "noConfigSearch": true,
  "allowCompoundWords": true,
  "words": [
    "CREDS",
    "hmpps",
    "mojdt",
    "govuk",
    "jgoz",
    "nomis",
    "clientid",
    "azuread",
    "xlink",
    "noopener",
    "noreferrer",
    "Familiarise",
    "NCSC",
    "ncsc",
    "CDDO",
    "WCAG",
    "scrying",
    "katex",
    "SLSA",
    "gomod",
    "textsf"
  ],
  "dictionaries": ["en-gb", "companies", "softwareTerms", "misc", "lorem-ipsum", "typescript", "node", "bash", "npm"],
  "languageSettings": [
    {
      "languageId": "commit-msg",
      "ignoreRegExpList": ["/^#.*/gm"]
    }
  ],
  "version": "0.2"
}